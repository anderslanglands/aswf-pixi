diff --git a/src/build/make_pyside6.py b/src/build/make_pyside6.py
index fd95ee53..41058cdc 100644
--- a/src/build/make_pyside6.py
+++ b/src/build/make_pyside6.py
@@ -212,24 +212,61 @@ def remove_broken_shortcuts(python_home: str) -> None:
                 print(f"Keeping {filepath}...")
 
 
+def find_qt_tool(tool_name: str) -> str:
+    """
+    Find a Qt tool in either the official Qt installer layout or conda-forge's
+    lib/qt6 layout.
+    """
+    suffix = ".exe" if platform.system() == "Windows" else ""
+    candidates = [
+        os.path.join(QT_OUTPUT_DIR, "bin", tool_name + suffix),
+        os.path.join(QT_OUTPUT_DIR, "bin", tool_name + "6" + suffix),
+        os.path.join(QT_OUTPUT_DIR, "lib", "qt6", "bin", tool_name + suffix),
+        os.path.join(QT_OUTPUT_DIR, "lib", "qt6", "bin", tool_name + "6" + suffix),
+        os.path.join(QT_OUTPUT_DIR, "lib", "qt6", tool_name + suffix),
+        os.path.join(QT_OUTPUT_DIR, "lib", "qt6", tool_name + "6" + suffix),
+    ]
+
+    for candidate in candidates:
+        if os.path.exists(candidate):
+            return candidate
+
+    raise FileNotFoundError(
+        f"Could not find Qt tool {tool_name!r} below {QT_OUTPUT_DIR!r}; checked: "
+        + ", ".join(candidates)
+    )
+
+
 def build() -> None:
     """
     Run the build step of the build. It compile every target of the project.
     """
     python_home = PYTHON_OUTPUT_DIR
     python_interpreter_args = get_python_interpreter_args(python_home, VARIANT)
+    qtpaths = find_qt_tool("qtpaths")
 
     pyside_build_args = python_interpreter_args + [
         os.path.join(SOURCE_DIR, "setup.py"),
         "install",
-        f"--qtpaths={os.path.join(QT_OUTPUT_DIR, 'bin', 'qtpaths' + ('.exe' if platform.system() == 'Windows' else ''))}",
+        f"--qtpaths={qtpaths}",
         "--ignore-git",
         "--standalone",
         "--verbose",
         "--verbose-build",
         "--log-level=verbose",
         f"--parallel={os.cpu_count() or 1}",
     ]
 
+    if platform.system() == "Linux":
+        shiboken_extra_include_paths = [os.path.join(QT_OUTPUT_DIR, "include")]
+        linux_sysroot_include = os.path.join(
+            QT_OUTPUT_DIR, "x86_64-conda-linux-gnu", "sysroot", "usr", "include"
+        )
+        if os.path.isdir(linux_sysroot_include):
+            shiboken_extra_include_paths.append(linux_sysroot_include)
+        pyside_build_args.append(
+            f"--shiboken-extra-include-paths={','.join(shiboken_extra_include_paths)}"
+        )
+
     if OPENSSL_OUTPUT_DIR:
         pyside_build_args.append(f"--openssl={os.path.join(OPENSSL_OUTPUT_DIR, 'bin')}")
