+ENDIF()
 
 IF(RV_TARGET_WINDOWS)
   GET_TARGET_PROPERTY(zlib_library ZLIB::ZLIB IMPORTED_IMPLIB)
@@ -79,7 +83,7 @@ EXTERNALPROJECT_ADD(
   INSTALL_COMMAND ${_cmake_install_command}
   BUILD_IN_SOURCE FALSE
