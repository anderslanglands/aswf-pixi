diff --git a/cmake/dependencies/tiff.cmake b/cmake/dependencies/tiff.cmake
--- a/cmake/dependencies/tiff.cmake
+++ b/cmake/dependencies/tiff.cmake
@@ -35,7 +35,11 @@ ELSE()
