diff --git a/cmake/dependencies/ocio.cmake b/cmake/dependencies/ocio.cmake
--- a/cmake/dependencies/ocio.cmake
+++ b/cmake/dependencies/ocio.cmake
@@ -153,8 +153,28 @@ LIST(APPEND _configure_options "-DOCIO_INSTALL_EXT_PACKAGES=MISSING")
 LIST(APPEND _configure_options "-Dyaml-cpp_ROOT=$ENV{PREFIX}")
 LIST(APPEND _configure_options "-Dminizip-ng_ROOT=$ENV{PREFIX}")
 LIST(APPEND _configure_options "-Dminizip-ng_INCLUDE_DIR=$ENV{PREFIX}/include/minizip")
 LIST(APPEND _configure_options "-Dminizip-ng_LIBRARY=$ENV{PREFIX}/lib/${CMAKE_SHARED_LIBRARY_PREFIX}minizip${CMAKE_SHARED_LIBRARY_SUFFIX}")
-
+
+SET(_ocio_conda_minizip_patch_script
+    ${CMAKE_BINARY_DIR}/RV_DEPS_OCIO_patch_conda_minizip.cmake
+)
+FILE(WRITE ${_ocio_conda_minizip_patch_script} [=[
+SET(_ocio_minizip_finder "${OCIO_SOURCE_DIR}/share/cmake/modules/Findminizip-ng.cmake")
+FILE(APPEND "${_ocio_minizip_finder}" [==[
+
+IF(TARGET MINIZIP::minizip-ng AND DEFINED ENV{PREFIX})
+  SET(_ocio_conda_minizip_library "$ENV{PREFIX}/lib/${CMAKE_SHARED_LIBRARY_PREFIX}minizip${CMAKE_SHARED_LIBRARY_SUFFIX}")
+  IF(EXISTS "${_ocio_conda_minizip_library}")
+    SET_TARGET_PROPERTIES(MINIZIP::minizip-ng PROPERTIES
+      IMPORTED_LOCATION "${_ocio_conda_minizip_library}"
+      IMPORTED_LOCATION_RELEASE "${_ocio_conda_minizip_library}"
+      INTERFACE_LINK_LIBRARIES "ZLIB::ZLIB")
+    SET(minizip-ng_LIBRARY "${_ocio_conda_minizip_library}" CACHE FILEPATH "minizip library" FORCE)
+  ENDIF()
+ENDIF()
+]==])
+]=])
+
 # OCIO apps are not needed.
 LIST(APPEND _configure_options "-DOCIO_BUILD_APPS=OFF")
 # Use MISSING so OCIO vendors its own third-party deps when not already provided by RV_DEPS (vs NONE/default), pinning versions and avoiding ABI/licensing drift
@@ -172,7 +192,8 @@ IF(NOT RV_TARGET_WINDOWS)
     SOURCE_DIR ${_source_dir}
     BINARY_DIR ${_build_dir}
     INSTALL_DIR ${_install_dir}
     DEPENDS Boost::headers RV_DEPS_PYTHON3 Imath::Imath ZLIB::ZLIB
+    PATCH_COMMAND ${CMAKE_COMMAND} "-DOCIO_SOURCE_DIR=${_source_dir}" -P "${_ocio_conda_minizip_patch_script}"
     CONFIGURE_COMMAND ${CMAKE_COMMAND} ${_configure_options}
     BUILD_COMMAND ${_cmake_build_command}
     INSTALL_COMMAND ${_cmake_install_command}
