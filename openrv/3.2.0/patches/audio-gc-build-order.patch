diff --git a/src/lib/audio/ALSAAudioModule/CMakeLists.txt b/src/lib/audio/ALSAAudioModule/CMakeLists.txt
index 93c7fec..094a6f4 100644
--- a/src/lib/audio/ALSAAudioModule/CMakeLists.txt
+++ b/src/lib/audio/ALSAAudioModule/CMakeLists.txt
@@ -27,6 +27,12 @@ TARGET_INCLUDE_DIRECTORIES(
   PUBLIC ${CMAKE_CURRENT_SOURCE_DIR} "$<TARGET_PROPERTY:IPCore,INTERFACE_INCLUDE_DIRECTORIES>"
 )
 
+# This plugin borrows include paths from IPCore without linking it, so keep the
+# external GC dependency ordered before compiling headers that include gc/gc.h.
+IF(TARGET BDWGC::Gc)
+  ADD_DEPENDENCIES(${_target} BDWGC::Gc)
+ENDIF()
+
 TARGET_LINK_LIBRARIES(
   ${_target}
   PRIVATE TwkAudio asound
