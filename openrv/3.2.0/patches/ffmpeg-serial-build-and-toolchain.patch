+FUNCTION(_rv_ffmpeg_to_msys_path _ffmpeg_path_var)
+  IF(NOT DEFINED ${_ffmpeg_path_var} OR "${${_ffmpeg_path_var}}" STREQUAL "")
+    RETURN()
+  ENDIF()
+  STRING(REPLACE "\\" "/" _ffmpeg_path "${${_ffmpeg_path_var}}")
+  STRING(REPLACE ":" "" _ffmpeg_path "${_ffmpeg_path}")
+  STRING(FIND "${_ffmpeg_path}" "/" _ffmpeg_first_slash_index)
+  IF(_ffmpeg_first_slash_index GREATER 0)
+    STRING(PREPEND _ffmpeg_path "/")
+  ENDIF()
+  SET(${_ffmpeg_path_var}
+      "${_ffmpeg_path}"
+      PARENT_SCOPE
+  )
+ENDFUNCTION()
