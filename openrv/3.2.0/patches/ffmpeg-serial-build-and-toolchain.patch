--- i/cmake/dependencies/ffmpeg.cmake
+++ w/cmake/dependencies/ffmpeg.cmake
@@ -323,6 +323,102 @@ ENDIF()
 LIST(JOIN _ffmpeg_pkg_config_path ":" _ffmpeg_pkg_config_path)
 
 SEPARATE_ARGUMENTS(RV_FFMPEG_PATCH_COMMAND_STEP)
+SET(_ffmpeg_configure_env
+    "PKG_CONFIG_PATH=${_ffmpeg_pkg_config_path}"
+)
+SET(_ffmpeg_toolchain_options)
+IF(CMAKE_C_COMPILER)
+  LIST(APPEND _ffmpeg_configure_env "CC=${CMAKE_C_COMPILER}" "LD=${CMAKE_C_COMPILER}")
+  LIST(APPEND _ffmpeg_toolchain_options "--cc=${CMAKE_C_COMPILER}" "--ld=${CMAKE_C_COMPILER}")
+ENDIF()
+IF(CMAKE_CXX_COMPILER)
+  LIST(APPEND _ffmpeg_configure_env "CXX=${CMAKE_CXX_COMPILER}")
+  LIST(APPEND _ffmpeg_toolchain_options "--cxx=${CMAKE_CXX_COMPILER}")
+ENDIF()
+IF(CMAKE_AR)
+  LIST(APPEND _ffmpeg_configure_env "AR=${CMAKE_AR}")
+  LIST(APPEND _ffmpeg_toolchain_options "--ar=${CMAKE_AR}")
+ENDIF()
+IF(CMAKE_RANLIB)
+  LIST(APPEND _ffmpeg_configure_env "RANLIB=${CMAKE_RANLIB}")
+  LIST(APPEND _ffmpeg_toolchain_options "--ranlib=${CMAKE_RANLIB}")
+ENDIF()
+IF(CMAKE_NM)
+  LIST(APPEND _ffmpeg_configure_env "NM=${CMAKE_NM}")
+  LIST(APPEND _ffmpeg_toolchain_options "--nm=${CMAKE_NM}")
+ENDIF()
+IF(CMAKE_STRIP)
+  LIST(APPEND _ffmpeg_configure_env "STRIP=${CMAKE_STRIP}")
+  LIST(APPEND _ffmpeg_toolchain_options "--strip=${CMAKE_STRIP}")
+ENDIF()
+IF(CMAKE_ASM_NASM_COMPILER)
+  LIST(APPEND _ffmpeg_configure_env "X86ASM=${CMAKE_ASM_NASM_COMPILER}")
+  LIST(APPEND _ffmpeg_toolchain_options "--x86asmexe=${CMAKE_ASM_NASM_COMPILER}")
+ENDIF()
+
+SET(_ffmpeg_build_command ${_make_command} -j1)
+SET(_ffmpeg_makefile_patch_script ${CMAKE_CURRENT_BINARY_DIR}/${_target}_patch_makefile.cmake)
+SET(_ffmpeg_common_mak ${RV_DEPS_BASE_DIR}/${_target}/src/ffbuild/common.mak)
+FILE(WRITE ${_ffmpeg_makefile_patch_script} "SET(_ffmpeg_common_mak [=[${_ffmpeg_common_mak}]=])\n")
+FILE(APPEND ${_ffmpeg_makefile_patch_script} [=[
+FILE(READ "${_ffmpeg_common_mak}" _ffmpeg_common)
+SET(_ffmpeg_original [==[
+$(OBJS):     | $(sort $(dir $(OBJS)))
+$(HOBJS):    | $(sort $(dir $(HOBJS)))
+$(HOSTOBJS): | $(sort $(dir $(HOSTOBJS)))
+$(SHLIBOBJS): | $(sort $(dir $(SHLIBOBJS)))
+$(STLIBOBJS): | $(sort $(dir $(STLIBOBJS)))
+$(TESTOBJS): | $(sort $(dir $(TESTOBJS)))
+$(TOOLOBJS): | tools
+]==])
+SET(_ffmpeg_replacement [==[
+_CONDARV_FFMPEG_OBJS := $(sort $(OBJS) $(SHLIBOBJS) $(STLIBOBJS))
+_CONDARV_FFMPEG_OBJ_DIRS := $(sort $(dir $(_CONDARV_FFMPEG_OBJS)))
+_CONDARV_FFMPEG_C_OBJS := $(sort $(patsubst %.c,%.o,$(wildcard $(_CONDARV_FFMPEG_OBJS:.o=.c))))
+_CONDARV_FFMPEG_CXX_OBJS := $(sort $(patsubst %.cpp,%.o,$(wildcard $(_CONDARV_FFMPEG_OBJS:.o=.cpp))))
+_CONDARV_FFMPEG_S_OBJS := $(sort $(patsubst %.S,%.o,$(wildcard $(_CONDARV_FFMPEG_OBJS:.o=.S))))
+_CONDARV_FFMPEG_ASM_OBJS := $(sort $(patsubst %.asm,%.o,$(wildcard $(_CONDARV_FFMPEG_OBJS:.o=.asm))))
+
+ifneq ($(strip $(_CONDARV_FFMPEG_C_OBJS)),)
+$(_CONDARV_FFMPEG_C_OBJS): %.o: %.c | $(_CONDARV_FFMPEG_OBJ_DIRS)
+	$(CC) -I. -I$(SRC_LINK)/ $(CPPFLAGS) $(CFLAGS) $(CC_DEPFLAGS) $(CC_C) $(CC_O) $(patsubst $(SRC_PATH)/%,$(SRC_LINK)/%,$<)
+endif
+ifneq ($(strip $(_CONDARV_FFMPEG_CXX_OBJS)),)
+$(_CONDARV_FFMPEG_CXX_OBJS): %.o: %.cpp | $(_CONDARV_FFMPEG_OBJ_DIRS)
+	$(CXX) -I. -I$(SRC_LINK)/ $(CPPFLAGS) $(CFLAGS) $(CXXFLAGS) $(CXX_DEPFLAGS) $(CXX_C) $(CXX_O) $(patsubst $(SRC_PATH)/%,$(SRC_LINK)/%,$<)
+endif
+ifneq ($(strip $(_CONDARV_FFMPEG_S_OBJS)),)
+$(_CONDARV_FFMPEG_S_OBJS): %.o: %.S | $(_CONDARV_FFMPEG_OBJ_DIRS)
+	$(AS) -I. -I$(SRC_LINK)/ $(CPPFLAGS) $(ASFLAGS) $(AS_DEPFLAGS) $(AS_C) $(AS_O) $(patsubst $(SRC_PATH)/%,$(SRC_LINK)/%,$<)
+endif
+ifneq ($(strip $(_CONDARV_FFMPEG_ASM_OBJS)),)
+$(_CONDARV_FFMPEG_ASM_OBJS): %.o: %.asm | $(_CONDARV_FFMPEG_OBJ_DIRS)
+	$(X86ASM) -I./ -I$(SRC_LINK)// -I$(<D)/ -Pconfig.asm $(X86ASMFLAGS) $(X86ASM_DEPFLAGS) $(X86ASM_O) $(patsubst $(SRC_PATH)/%,$(SRC_LINK)/%,$<)
+	-$(if $(ASMSTRIPFLAGS), $(STRIP) $(ASMSTRIPFLAGS) $@)
+endif
+
+$(HOBJS):    | $(sort $(dir $(HOBJS)))
+$(HOSTOBJS): | $(sort $(dir $(HOSTOBJS)))
+$(TESTOBJS): | $(sort $(dir $(TESTOBJS)))
+$(TOOLOBJS): | tools
+]==])
+STRING(FIND "${_ffmpeg_common}" "${_ffmpeg_replacement}" _ffmpeg_already_patched)
+IF(_ffmpeg_already_patched EQUAL -1)
+  STRING(FIND "${_ffmpeg_common}" "${_ffmpeg_original}" _ffmpeg_patch_position)
+  IF(_ffmpeg_patch_position EQUAL -1)
+    MESSAGE(FATAL_ERROR "Unable to find FFmpeg common.mak object rule block to patch")
+  ENDIF()
+  STRING(REPLACE "${_ffmpeg_original}" "${_ffmpeg_replacement}" _ffmpeg_common "${_ffmpeg_common}")
+  FILE(WRITE "${_ffmpeg_common_mak}" "${_ffmpeg_common}")
+ENDIF()
+]=])
+
+SET(_ffmpeg_patch_command ${RV_FFMPEG_PATCH_COMMAND_STEP})
+IF(_ffmpeg_patch_command)
+  LIST(APPEND _ffmpeg_patch_command COMMAND ${CMAKE_COMMAND} -P ${_ffmpeg_makefile_patch_script})
+ELSE()
+  SET(_ffmpeg_patch_command ${CMAKE_COMMAND} -P ${_ffmpeg_makefile_patch_script})
+ENDIF()
 
 EXTERNALPROJECT_ADD(
   ${_target}
