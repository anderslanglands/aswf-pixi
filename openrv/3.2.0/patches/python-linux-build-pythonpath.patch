diff --git i/src/build/make_python.py w/src/build/make_python.py
index 209a42e..c007ba6 100644
--- i/src/build/make_python.py
+++ w/src/build/make_python.py
@@ -361,0 +362,28 @@ def configure() -> None:
+                    if platform.system() == "Linux":
+                        # CPython's generated pybuilddir.txt rule invokes the
+                        # in-tree interpreter before the stdlib is installed. In
+                        # rattler-build prefixes that can leave it unable to find
+                        # Lib/encodings. Put the source Lib directory on just the
+                        # generated build command without baking it into the
+                        # installed interpreter.
+                        source_lib = os.path.join(SOURCE_DIR, "Lib")
+                        if new_line.startswith("PYTHON_FOR_BUILD="):
+                            new_line = new_line.replace("./python -E", f"PYTHONPATH={source_lib} ./python")
+                        new_line = new_line.replace(
+                            "$(RUNSHARED) $(PYTHON_FOR_BUILD) -S -m sysconfig --generate-posix-vars",
+                            f"PYTHONPATH={source_lib} $(RUNSHARED) ./python -S -m sysconfig --generate-posix-vars",
+                        )
+                        new_line = new_line.replace(
+                            "$(RUNSHARED) $(PYTHON_FOR_BUILD) -c",
+                            f"PYTHONPATH={source_lib} $(RUNSHARED) ./python -c",
+                        )
+                        new_line = new_line.replace(
+                            "@$(RUNSHARED) $(srcdir)/if_runnable.sh $(PYTHON_FOR_BUILD) $(srcdir)/Tools/build/check_extension_modules.py",
+                            '@echo "Skipping checksharedmods during OpenRV dependency build"',
+                        )
+                        new_line = new_line.replace(
+                            "$(RUNSHARED) $(srcdir)/if_runnable.sh $(PYTHON_FOR_BUILD)",
+                            f"PYTHONPATH={source_lib} $(RUNSHARED) ./python",
+                        )
+                        if "$(srcdir)/Tools/build/check_extension_modules.py" in new_line:
+                            new_line = '\t@echo "Skipping checksharedmods during OpenRV dependency build"\n'
@@ -475 +504,4 @@ def install_python_vfx2023() -> None:
-        make_args = ["make", "install", f"-j{os.cpu_count() or 1}", "-s"]
+        if platform.system() == "Linux":
+            make_args = ["make", "install", "-j1", "-s"]
+        else:
+            make_args = ["make", "install", f"-j{os.cpu_count() or 1}", "-s"]
@@ -478,2 +510,4 @@ def install_python_vfx2023() -> None:
         subprocess_env = {**os.environ}
+        if platform.system() == "Linux":
+            subprocess_env["PYTHONPATH"] = os.path.join(SOURCE_DIR, "Lib")
         if OPENSSL_OUTPUT_DIR:
