+
+
+def _prefix_from_executable() -> str or None:
+    executable = os.path.realpath(sys.executable)
+    bin_dir = os.path.dirname(executable)
+    if os.path.basename(bin_dir).lower() in ("bin", "scripts"):
+        return os.path.dirname(bin_dir)
+    return None
+
+
+def _expand_tool_path(path: str) -> str:
+    expanded = os.path.expandvars(path)
+    build_prefix = os.environ.get("BUILD_PREFIX") or _prefix_from_executable()
+    if build_prefix:
+        expanded = expanded.replace("${BUILD_PREFIX}", build_prefix).replace("$BUILD_PREFIX", build_prefix)
+    prefix = os.environ.get("PREFIX")
+    if prefix:
+        expanded = expanded.replace("${PREFIX}", prefix).replace("$PREFIX", prefix)
+    return expanded
+
+
+def _find_7zip() -> str:
+    candidates = ("7zz", "7z", "7za")
+    checked = set()
+
+    def candidate_paths():
+        for candidate in candidates:
+            seven_zip = shutil.which(candidate)
+            if seven_zip:
+                yield seven_zip
+
+        for path_dir in os.environ.get("PATH", "").split(os.pathsep):
+            expanded_dir = _expand_tool_path(path_dir)
+            if not expanded_dir or "$" in expanded_dir:
+                continue
+            for candidate in candidates:
+                yield os.path.join(expanded_dir, candidate)
+
+        for root in (os.environ.get("BUILD_PREFIX"), _prefix_from_executable(), os.environ.get("PREFIX")):
+            if not root:
+                continue
+            for candidate in candidates:
+                yield os.path.join(root, "bin", candidate)
+
+    for seven_zip in candidate_paths():
+        seven_zip = _expand_tool_path(seven_zip)
+        if seven_zip in checked or "$" in seven_zip:
+            continue
+        checked.add(seven_zip)
+        if os.path.exists(seven_zip):
+            return seven_zip
+
+    raise RuntimeError(
+        "Could not find a 7zip executable. Install the 7zip build requirement."
+    )
+
+
+def _run_7zip(args: List[str], *, allow_dangerous_links: bool = False, check: bool = True) -> bool:
+    print(f"Executing {args}")
+    result = subprocess.run(args, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)
+    if result.stdout:
+        print(result.stdout, end="" if result.stdout.endswith("\n") else "\n")
+
+    ignored_dangerous_links = (
+        allow_dangerous_links
+        and result.returncode == 2
+        and "Dangerous link via another link was ignored" in result.stdout
+    )
+    if ignored_dangerous_links:
+        print("Ignoring 7zip dangerous-link warnings from libclang symlinks")
+        return True
+
+    if result.returncode != 0:
+        if check:
+            result.check_returncode()
+        return False
+
+    return True
+
+
+class _SystemSevenZipFile:
+    def __init__(self, input_7z: str, mode: str) -> None:
+        if mode != "r":
+            raise ValueError(f"Unsupported 7z mode: {mode}")
+        self.input_7z = input_7z
+
+    def __enter__(self):
+        return self
+
+    def __exit__(self, exc_type, exc_value, traceback):
+        return False
+
+    def extractall(self, output_folder: str) -> None:
+        extract_args = [_find_7zip(), "x", self.input_7z, f"-o{output_folder}", "-y"]
+        _run_7zip(extract_args, allow_dangerous_links=True)
+
+    def test(self) -> bool:
+        test_args = [_find_7zip(), "t", self.input_7z]
+        return _run_7zip(test_args, check=False)
+
+
+class _SystemSevenZipExceptions:
+    class Bad7zFile(Exception):
+        pass
+
+
+SevenZipFile = _SystemSevenZipFile
+exceptions = _SystemSevenZipExceptions
