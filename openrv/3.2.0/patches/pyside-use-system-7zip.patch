+def _find_7zip() -> str:
+    for candidate in ("7zz", "7z", "7za"):
+        seven_zip = shutil.which(candidate)
+        if seven_zip:
+            return os.path.expandvars(seven_zip)
+
+    for root in (os.environ.get("BUILD_PREFIX"), os.environ.get("PREFIX")):
+        if not root:
+            continue
+        for candidate in ("7zz", "7z", "7za"):
+            seven_zip = os.path.join(root, "bin", candidate)
+            if os.path.exists(seven_zip):
+                return seven_zip
+
+    raise RuntimeError(
+        "Could not find a 7zip executable. Install the 7zip build requirement."
+    )
+
+
+class _SystemSevenZipFile:
+    def __init__(self, input_7z: str, mode: str) -> None:
+        if mode != "r":
+            raise ValueError(f"Unsupported 7z mode: {mode}")
+        self.input_7z = input_7z
+
+    def __enter__(self):
+        return self
+
+    def __exit__(self, exc_type, exc_value, traceback):
+        return False
+
+    def extractall(self, output_folder: str) -> None:
+        extract_args = [_find_7zip(), "x", self.input_7z, f"-o{output_folder}", "-y"]
+        print(f"Executing {extract_args}")
+        subprocess.run(extract_args).check_returncode()
+
+    def test(self) -> bool:
+        test_args = [_find_7zip(), "t", self.input_7z]
+        print(f"Executing {test_args}")
+        return subprocess.run(test_args).returncode == 0
+
+
+class _SystemSevenZipExceptions:
+    class Bad7zFile(Exception):
+        pass
+
+
+SevenZipFile = _SystemSevenZipFile
+exceptions = _SystemSevenZipExceptions
