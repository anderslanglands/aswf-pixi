diff --git a/cmake/dependencies/aja.cmake b/cmake/dependencies/aja.cmake
--- a/cmake/dependencies/aja.cmake
+++ b/cmake/dependencies/aja.cmake
@@ -69,0 +70,50 @@
+SET(_aja_patch_command "")
+IF(RV_TARGET_DARWIN)
+  SET(_aja_macos_sdk_patch_script
+      ${CMAKE_CURRENT_BINARY_DIR}/${_target}_patch_macos_sdk.cmake
+  )
+  FILE(WRITE ${_aja_macos_sdk_patch_script} [==[
+SET(_aja_cmake_options "${_source_dir}/cmake/CMakeOptions.cmake")
+FILE(READ "${_aja_cmake_options}" _aja_cmake_options_text)
+SET(_aja_original [=[    get_filename_component(MACOS_SDK_NAME ${CMAKE_OSX_SYSROOT} NAME_WLE)
+    string(REPLACE "MacOSX" "" MACOS_SDK_VERSION ${MACOS_SDK_NAME})
+    string(REPLACE "." ";" MACOS_SDK_VERSION_LIST ${MACOS_SDK_VERSION})
+    list(GET MACOS_SDK_VERSION_LIST 0 MACOS_SDK_VERSION_MAJOR)
+    list(GET MACOS_SDK_VERSION_LIST 1 MACOS_SDK_VERSION_MINOR)
+]=])
+SET(_aja_replacement [=[    get_filename_component(MACOS_SDK_NAME ${CMAKE_OSX_SYSROOT} NAME_WLE)
+    string(REPLACE "MacOSX" "" MACOS_SDK_VERSION "${MACOS_SDK_NAME}")
+    if(NOT MACOS_SDK_VERSION)
+        execute_process(
+            COMMAND xcrun --sdk macosx --show-sdk-version
+            OUTPUT_VARIABLE MACOS_SDK_VERSION
+            OUTPUT_STRIP_TRAILING_WHITESPACE
+            ERROR_QUIET
+        )
+    endif()
+    if(NOT MACOS_SDK_VERSION)
+        set(MACOS_SDK_VERSION "0.0")
+    endif()
+    string(REPLACE "." ";" MACOS_SDK_VERSION_LIST "${MACOS_SDK_VERSION}")
+    list(GET MACOS_SDK_VERSION_LIST 0 MACOS_SDK_VERSION_MAJOR)
+    list(LENGTH MACOS_SDK_VERSION_LIST MACOS_SDK_VERSION_COMPONENT_COUNT)
+    if(MACOS_SDK_VERSION_COMPONENT_COUNT GREATER 1)
+        list(GET MACOS_SDK_VERSION_LIST 1 MACOS_SDK_VERSION_MINOR)
+    else()
+        set(MACOS_SDK_VERSION_MINOR 0)
+    endif()
+]=])
+IF(_aja_cmake_options_text MATCHES "xcrun --sdk macosx --show-sdk-version")
+  RETURN()
+ENDIF()
+STRING(FIND "${_aja_cmake_options_text}" "${_aja_original}" _aja_patch_position)
+IF(_aja_patch_position EQUAL -1)
+  MESSAGE(FATAL_ERROR "Unable to find AJA macOS SDK version block to patch")
+ENDIF()
+STRING(REPLACE "${_aja_original}" "${_aja_replacement}" _aja_cmake_options_text "${_aja_cmake_options_text}")
+FILE(WRITE "${_aja_cmake_options}" "${_aja_cmake_options_text}")
+]==])
+  SET(_aja_patch_command
+      ${CMAKE_COMMAND} -D_source_dir=${_source_dir} -P ${_aja_macos_sdk_patch_script}
+  )
+ENDIF()
@@ -80,0 +131 @@
+  PATCH_COMMAND ${_aja_patch_command}
